# Change File name to .env, enter client id and secret, place in the same folder
# Comma-separated list of ICAO24 values to poll continuously.
TRACKED_ICAO24S=a6a6fe

# Poll interval in milliseconds.
POLL_MS=100000

# Kafka connection for local development.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=plane-fetcher
KAFKA_TOPIC_PLANES_UPDATES=planes.opensky.updates
KAFKA_TOPIC_PLANES_ERRORS=planes.opensky.errors

# Need to enter opensky client id and client secret
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
